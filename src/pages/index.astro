        <path d="M17.472 14.382c-.301-.15-1.781-.879-2.056-.979-.275-.1-.475-.15-.675.15-.199.299-.775.979-.95 1.174-.175.195-.349.219-.65.069-.3-.15-1.265-.467-2.41-1.487-.89-.793-1.49-1.773-1.665-2.07-.175-.3-.019-.461.13-.61.135-.134.3-.349.45-.524.15-.174.199-.299.299-.499.1-.2.05-.374-.025-.524-.075-.15-.675-1.625-.925-2.225-.244-.585-.494-.504-.675-.514-.175-.00
</body>
</html>