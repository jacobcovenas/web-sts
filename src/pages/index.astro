            if (isOpen) {
                menu.classList.add('hidden');
                icon.setAttribute('d', 'M4 6h16M4 12h16m-7 6h7');
            } else {
                menu.classList.remove('hidden');
                icon.setAttribute('d', 'M6 18L18 6M6 6l12 12'); 
            }
        });

        links.forEach(link => {
            link.addEventListener('click', () => {
                menu.classList.add('hidden');
                icon.setAttribute('d', 'M4 6h16M4 12h16m-7 6h7');
            });
        });
    })();
</script>
</body>
</html>