        </svg>
        <span class="text-[9px] sm:text-[10px] font-bold tracking-widest uppercase">958 322 241</span>
    </a>

    <a href="mailto:ventas@stsllantas.com" class="hidden md:flex items-center gap-2 group">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-blue-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        <span class="text-[10px] font-bold tracking-widest uppercase text-blue-100 italic">ventas@stsllantas.com</span>
    </a>
</div>

        <div class="flex items-center gap-4">
            <a href="#" target="_blank" class="text-white hover:text-blue-300 transition-colors" aria-label="Facebook">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/>
                </svg>
            </a>
            <a href="#" target="_blank" class="text-white hover:text-blue-300 transition-colors" aria-label="Instagram">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
            </a>
        </div>
    </div>
</div>

    <nav class="w-full bg-white border-b border-gray-100 h-20 flex items-center">
    <div class="container mx-auto px-6 flex justify-between items-center w-full">
        
        <div class="flex-shrink-0">
            <img src="/logo-sts.png" alt="Logo de South Tires Solutions" class="h-9 md:h-11 w-auto">            
        </div>
        
        <div class="hidden lg:flex items-center gap-8 font-black text-[10px] tracking-widest text-blue-900 italic">
            <a href="#inicio" class="hover:text-red-600 transition uppercase">INICIO</a>
            <a href="#sectores" class="hover:text-red-600 transition uppercase">PRODUCTOS</a>
            <a href="#catalogo" class="hover:text-red-600 transition uppercase">CATÁLOGO</a>
            <a href="#blog" class="hover:text-red-600 transition uppercase">BLOG</a>
            <a href="#contacto" class="hover:text-red-600 transition uppercase">CONTACTO</a>
            <a href="https://wa.me/51958322241" target="_blank" class="bg-blue-900 text-white px-6 py-2.5 rounded-full hover:bg-red-600 transition shadow-md not-italic uppercase">COTIZAR</a>
        </div>
        
        <button 
            id="menu-btn" 
            class="lg:hidden flex items-center gap-2 p-2 text-blue-900 focus:outline-none group"
            aria-label="Abrir menú de navegación"
            aria-expanded="false"
            aria-controls="mobile-menu"
        >
            <span class="text-[10px] font-black tracking-widest uppercase group-hover:text-red-600 transition">Menú</span>
            
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 group-hover:text-red-600 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
            </svg>
        </button>
    </div>
</nav>

</header>

<section id="inicio" class="relative h-screen flex items-center pt-20 overflow-hidden">
    <div class="absolute inset-0 z-0">
        <Image 
            src={heroSts} 
            alt="Maquinaria pesada STS" 
            width={1920} 
            height={1080}
            format="webp"
            quality={80}
            loading="eager" 
            fetchpriority="high"
            class="w-full h-full object-cover brightness-[0.4]"
        />
    </div>
    <div class="container mx-auto px-6 relative z-10">
        <div class="max-w-3xl">
            <span class="text-red-500 font-bold tracking-widest uppercase text-sm mb-4 block underline decoration-2 underline-offset-8">Confianza y Rendimiento</span>
            <h1 class="text-5xl md:text-7xl font-extrabold text-white leading-tight mb-6">
                Llantas para los terrenos más <span class="text-red-600">exigentes.</span>
            </h1>
            <p class="text-xl text-gray-300 mb-10 leading-relaxed">
                Especialistas en sectores Agrícola, Industrial, OTR y Transporte Pesado. Asesoría profesional y despacho a nivel nacional.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
                <a href="#catalogo" class="bg-white text-blue-900 px-8 py-4 rounded-lg font-bold text-center hover:bg-gray-100 transition">Ver Catálogo</a>                    
            </div>
        </div>
    </div>
</section>


<section class="py-16 bg-gray-50 border-y border-gray-100">
    <div class="container mx-auto px-6">
        <div class="text-center mb-16">
    <h2 class="text-3xl md:text-5xl font-black text-blue-900 mb-4 tracking-tighter uppercase leading-none">
        ESTAS SON NUESTRAS MARCAS <span class="text-gray-500 font-black">MÁS SOLICITADAS</span>
    </h2>
    <div class="w-24 h-1.5 bg-blue-900 mx-auto mb-6"></div>
    <p class="text-gray-500 max-w-3xl mx-auto text-lg font-medium uppercase tracking-widest text-sm">
        Respaldo y garantía de fabricantes líderes a nivel mundial
    </p>
</div>
        
        <div class="max-w-5xl mx-auto">
            <div class="relative">
                <img 
                    src="/marcas-aliadas.jpg" 
                    alt="Marcas aliadas de STS: Michelin, Goodyear, Triangle y más" 
                    class="w-full h-auto"
                />
            </div>
        </div>
    </div>
</section>    

<section id="sectores" class="py-24 bg-white">
    <div class="container mx-auto px-6">
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-5xl font-black text-blue-900 mb-4 tracking-tighter uppercase">
                LLANTAS PARA CADA INDUSTRIA Y TERRENO.
            </h2>
            <div class="w-24 h-1 bg-red-600 mx-auto mb-6"></div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            
            {/* Usamos un array para renderizar las tarjetas de forma limpia */}
            {[
                { src: imgAgricola, title: "Agrícola", desc: "Tracción superior para tractores." },
                { src: imgIndustrial, title: "Industrial", desc: "Equipos de manipulación de carga." },
                { src: imgMontacarga, title: "Montacarga", desc: "Llantas sólidas y neumáticas." },
                { src: imgConstruccion, title: "Construcción", desc: "Resistencia para retroexcavadoras." },
                { src: imgMineria, title: "Minería", desc: "Llantas OTR para condiciones extremas." },
                { src: imgTransporte, title: "Camión", desc: "Máximo kilometraje en carretera." },
                { src: imgCamioneta, title: "Camioneta", desc: "Llantas AT/MT para todo terreno." },
                { src: imgAuto, title: "Auto", desc: "Seguridad y confort urbano." }
            ].map((sector) => (
                <div class="group overflow-hidden rounded-2xl shadow-md border border-gray-100 hover:shadow-2xl transition-all duration-500 bg-white">
                    <div class="h-48 overflow-hidden">
                        <Image 
                            src={sector.src} 
                            alt={`Sector ${sector.title}`}
                            width={600}
                            height={400}
                            format="webp"
                            quality="mid"
                            class="w-full h-full object-cover group-hover:scale-110 transition duration-700"
                        />
                    </div>
                    <div class="p-6">
                        <h3 class="text-xl font-black text-blue-900 mb-2 uppercase tracking-tighter">{sector.title}</h3>
                        <p class="text-gray-500 text-xs leading-relaxed">{sector.desc}</p>
                    </div>
                </div>
            ))}

        </div>
    </div>
</section>

<section id="servicios" class="w-full bg-white py-24 relative overflow-hidden">
  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-black text-blue-900 uppercase tracking-tighter mb-4">
        Nuestros Servicios
      </h2>
      <div class="w-16 h-1 bg-blue-900 mx-auto mb-6"></div>
      <p class="text-gray-500 text-sm font-bold max-w-2xl mx-auto uppercase tracking-[0.3em]">
        Los mejores servicios a disposición

      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      
      <div class="group bg-gray-50 border border-gray-100 p-10 rounded-3xl hover:bg-blue-900 transition-all duration-500">
        <div class="mb-8 inline-block bg-blue-900 p-4 rounded-2xl text-white group-hover:bg-white group-hover:text-blue-900 transition-colors duration-500 shadow-xl">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="text-xl font-black text-blue-900 group-hover:text-white uppercase tracking-tight mb-4 transition-colors">
          Precios Competitivos
        </h3>
        <p class="text-gray-500 group-hover:text-blue-100 leading-relaxed text-sm font-medium transition-colors">
          Optimizamos su inversión garantizando las tarifas más competitivas del mercado nacional.
        </p>
      </div>

      <div class="group bg-gray-50 border border-gray-100 p-10 rounded-3xl hover:bg-blue-900 transition-all duration-500">
        <div class="mb-8 inline-block bg-blue-900 p-4 rounded-2xl text-white group-hover:bg-white group-hover:text-blue-900 transition-colors duration-500 shadow-xl">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
          </svg>
        </div>
        <h3 class="text-xl font-black text-blue-900 group-hover:text-white uppercase tracking-tight mb-4 transition-colors">
          Variedad de Marcas
        </h3>
        <p class="text-gray-500 group-hover:text-blue-100 leading-relaxed text-sm font-medium transition-colors">
          Portafolio multimarca de alto rendimiento con respaldo y garantía de fábrica global.
        </p>
      </div>

      <div class="group bg-gray-50 border border-gray-100 p-10 rounded-3xl hover:bg-blue-900 transition-all duration-500">
        <div class="mb-8 inline-block bg-blue-900 p-4 rounded-2xl text-white group-hover:bg-white group-hover:text-blue-900 transition-colors duration-500 shadow-xl">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1" />
          </svg>
        </div>
        <h3 class="text-xl font-black text-blue-900 group-hover:text-white uppercase tracking-tight mb-4 transition-colors">
          Atención Nacional
        </h3>
        <p class="text-gray-500 group-hover:text-blue-100 leading-relaxed text-sm font-medium transition-colors">
          Logística eficiente con envíos directos en Lima y despacho nacional vía agencias líderes.
        </p>
      </div>

      <div class="group bg-gray-50 border border-gray-100 p-10 rounded-3xl hover:bg-blue-900 transition-all duration-500">
        <div class="mb-8 inline-block bg-blue-900 p-4 rounded-2xl text-white group-hover:bg-white group-hover:text-blue-900 transition-colors duration-500 shadow-xl">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />
          </svg>
        </div>
        <h3 class="text-xl font-black text-blue-900 group-hover:text-white uppercase tracking-tight mb-4 transition-colors">
          Instalación Técnica
        </h3>
        <p class="text-gray-500 group-hover:text-blue-100 leading-relaxed text-sm font-medium transition-colors">
          Servicio especializado con equipos de precisión para asegurar la vida útil de sus neumáticos.
        </p>
      </div>

      <div class="group bg-gray-50 border border-gray-100 p-10 rounded-3xl hover:bg-blue-900 transition-all duration-500">
        <div class="mb-8 inline-block bg-blue-900 p-4 rounded-2xl text-white group-hover:bg-white group-hover:text-blue-900 transition-colors duration-500 shadow-xl">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
        </div>
        <h3 class="text-xl font-black text-blue-900 group-hover:text-white uppercase tracking-tight mb-4 transition-colors">
          Asesoría Especializada
        </h3>
        <p class="text-gray-500 group-hover:text-blue-100 leading-relaxed text-sm font-medium transition-colors">
          Acompañamiento técnico para seleccionar la llanta idónea según su terreno y operación.
        </p>
      </div>

      <div class="group bg-gray-50 border border-gray-100 p-10 rounded-3xl hover:bg-blue-900 transition-all duration-500">
        <div class="mb-8 inline-block bg-blue-900 p-4 rounded-2xl text-white group-hover:bg-white group-hover:text-blue-900 transition-colors duration-500 shadow-xl">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
