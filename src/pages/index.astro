---
import '../styles/global.css';
import { Image } from 'astro:assets';

// Importamos las imágenes desde la nueva ubicación en assets
import heroSts from '../assets/hero-sts.jpg';
import imgAgricola from '../assets/sector-agricola.jpg';
import imgIndustrial from '../assets/sector-industrial.jpg';
import imgMontacarga from '../assets/sector-montacarga.jpg';
import imgConstruccion from '../assets/sector-construccion.jpg';
import imgMineria from '../assets/sector-mineria.jpg';
import imgTransporte from '../assets/sector-transporte.jpg';
import imgCamioneta from '../assets/sector-camioneta.jpg';
import imgAuto from '../assets/sector-auto.jpg';
import almacenSts from '../assets/almacen-sts.jpg';
import imgContacto from '../assets/contacto.jpg';
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    
    <title>South Tires Solutions SAC | Llantas OTR, Agrícolas e Industriales en Perú</title>
    <meta name="description" content="Especialistas en llantas de alta resistencia para minería, construcción y agricultura. Distribución nacional desde Cañete y Lima. South Tires Solutions SAC garantiza rendimiento extremo.">
    <meta name="keywords" content="Llantas OTR Perú, Neumáticos industriales, Llantas para minería, South Tires Solutions, Llantas Cañete, Llantas agrícolas">
    <meta name="author" content="South Tires Solutions SAC">

    <meta property="og:type" content="website">
    <meta property="og:url" content="https://www.stsllantas.com/">
    <meta property="og:title" content="South Tires Solutions SAC | Potencia en cada terreno">
    <meta property="og:description" content="Venta y asesoría de llantas industriales y OTR en todo el Perú.">
    <meta property="og:image" content="/hero-sts.jpg">

    <link rel="canonical" href="https://www.stsllantas.com/">

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "South Tires Solutions SAC",
  "image": "https://www.stsllantas.com/logo-sts.png",
  "@id": "https://www.stsllantas.com",
  "url": "https://www.stsllantas.com",
  "telephone": "+51958322241",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Jr. Garro 280",
    "addressLocality": "San Vicente de Cañete",
    "addressRegion": "Lima",
    "addressCountry": "PE"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -13.075, 
    "longitude": -76.385
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday",
      "Saturday"
    ],
    "opens": "08:00",
    "closes": "18:00"
  },
  "sameAs": [
    "https://www.facebook.com/STSLLANTAS"   
  ]
}
</script>

</head>
<body class="font-sans antialiased text-slate-900">
<header class="sticky top-0 w-full z-[100] shadow-sm">
    
    <div class="w-full bg-blue-900 py-2">
    <div class="container mx-auto px-6 flex justify-between items-center text-white">
        <div class="flex items-center gap-4 sm:gap-6">
    <a href="tel:+51966022790" class="flex items-center gap-1.5 group">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-blue-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        <span class="text-[9px] sm:text-[10px] font-bold tracking-widest uppercase">966 022 790</span>
    </a>

    <a href="https://wa.me/51958322241" target="_blank" class="flex items-center gap-1.5 group">
