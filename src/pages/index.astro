---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    
    <title>South Tires Solutions SAC | Llantas OTR, Agrícolas e Industriales en Perú</title>
    <meta name="description" content="Especialistas en llantas de alta resistencia para minería, construcción y agricultura. Distribución nacional desde Cañete y Lima. South Tires Solutions SAC garantiza rendimiento extremo.">
    <meta name="keywords" content="Llantas OTR Perú, Neumáticos industriales, Llantas para minería, South Tires Solutions, Llantas Cañete, Llantas agrícolas">
    <meta name="author" content="South Tires Solutions SAC">

    <meta property="og:type" content="website">
    <meta property="og:url" content="https://www.stsllantas.com/">
    <meta property="og:title" content="South Tires Solutions SAC | Potencia en cada terreno">
    <meta property="og:description" content="Venta y asesoría de llantas industriales y OTR en todo el Perú.">
    <meta property="og:image" content="/hero-sts.jpg">

    <link rel="canonical" href="https://www.stsllantas.com/">

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "South Tires Solutions SAC",
  "image": "https://www.stsllantas.com/logo-sts.png",
  "@id": "https://www.stsllantas.com",
  "url": "https://www.stsllantas.com",
  "telephone": "+51958322241",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Jr. Garro 280",
    "addressLocality": "San Vicente de Cañete",
    "addressRegion": "Lima",
    "addressCountry": "PE"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -13.075, 
    "longitude": -76.385
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday",
      "Saturday"
    ],
    "opens": "08:00",
    "closes": "18:00"
  },
  "sameAs": [
    "https://www.facebook.com/tu-pagina",
    "https://www.instagram.com/tu-pagina"
  ]
}
</script>

</head>
<body class="font-sans antialiased text-slate-900">
    <nav class="fixed w-full z-50 bg-white/90 backdrop-blur-sm border-b border-gray-200 py-4">
        <div class="container mx-auto px-6 flex justify-between items-center">
            <div class="flex items-center gap-2">
                <img src="/logo-sts.png" alt="STS Logo" class="h-10 w-auto">
                <span class="font-bold text-xl tracking-tighter text-blue-900">South Tires Solutions SAC</span>
            </div>
            <div class="hidden md:flex gap-8 font-medium">
                <a href="#inicio" class="hover:text-red-600 transition">Inicio</a>
                <a href="#sectores" class="hover:text-red-600 transition">Sectores</a>
                <a href="#catalogo" class="hover:text-red-600 transition">Catálogo</a>
                <a href="#nosotros" class="hover:text-red-600 transition">Nosotros</a>
            </div>
            <a href="https://wa.me/51958322241?text=Hola%20STS,%20vengo%20de%20la%20web" class="bg-red-600 text-white px-5 py-2 rounded-md font-bold text-sm hover:bg-red-700 transition">COTIZAR</a>
        </div>
    </nav>

    <section id="inicio" class="relative h-screen flex items-center pt-20 overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img 
                src="/hero-sts.jpg" 
                class="w-full h-full object-cover brightness-[0.4]" 
                alt="Maquinaria pesada STS"
            >
        </div>
        <div class="container mx-auto px-6 relative z-10">
            <div class="max-w-3xl">
                <span class="text-red-500 font-bold tracking-widest uppercase text-sm mb-4 block underline decoration-2 underline-offset-8">Confianza y Rendimiento</span>
                <h1 class="text-5xl md:text-7xl font-extrabold text-white leading-tight mb-6">
                    Llantas para los terrenos más <span class="text-red-600">exigentes.</span>
                </h1>
                <p class="text-xl text-gray-300 mb-10 leading-relaxed">
                    Especialistas en sectores Agrícola, Industrial, OTR y Transporte Pesado. Asesoría profesional y despacho a nivel nacional.
                </p>
                <div class="flex flex-col sm:flex-row gap-4">
                    <a href="#catalogo" class="bg-white text-blue-900 px-8 py-4 rounded-lg font-bold text-center hover:bg-gray-100 transition">Ver Catálogo PDF</a>
                    <a href="https://wa.me/51958322241" class="bg-red-600 text-white px-8 py-4 rounded-lg font-bold text-center hover:bg-red-700 transition">Asesoría Inmediata</a>
                </div>
            </div>
        </div>
    </section>

<section id="sectores" class="py-24 bg-white">
    <div class="container mx-auto px-6">
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-5xl font-bold text-blue-900 mb-4 tracking-tight">Especialistas por Sector</h2>
            <div class="w-24 h-1 bg-red-600 mx-auto mb-6"></div>
            <p class="text-gray-600 max-w-3xl mx-auto text-lg">
                Equipamos su maquinaria con neumáticos diseñados para las condiciones más extremas del Perú.
            </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            
            <div class="group overflow-hidden rounded-xl shadow-md border border-gray-100 hover:shadow-xl transition bg-blue-900 text-white lg:col-span-1">
                <div class="h-56 overflow-hidden">
                    <img src="/sector-mineria.jpg" alt="Minería" class="w-full h-full object-cover group-hover:scale-110 transition duration-500">
                </div>
                <div class="p-6">
                    <div class="flex justify-between items-start mb-2">
                        <h3 class="text-xl font-bold italic">Minería</h3>
                        <span class="bg-red-600 text-[10px] px-2 py-1 rounded font-bold uppercase">Heavy Duty</span>
                    </div>
                    <p class="text-blue-200 text-sm">Llantas OTR para tajos abiertos y socavones.</p>
                </div>
            </div>

            <div class="group overflow-hidden rounded-xl shadow-md border border-gray-100 hover:shadow-xl transition">
                <div class="h-56 overflow-hidden">
                    <img src="/sector-agricola.jpg" alt="Agrícola" class="w-full h-full object-cover group-hover:scale-110 transition duration-500">
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-bold text-blue-900 mb-2">Agrícola</h3>
                    <p class="text-gray-500 text-sm">Tracción superior para tractores y cosechadoras.</p>
                </div>
            </div>

            <div class="group overflow-hidden rounded-xl shadow-md border border-gray-100 hover:shadow-xl transition">
                <div class="h-56 overflow-hidden">
                    <img src="/sector-construccion.jpg" alt="Construcción" class="w-full h-full object-cover group-hover:scale-110 transition duration-500">
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-bold text-blue-900 mb-2">Construcción</h3>
                    <p class="text-gray-500 text-sm">Resistencia para retroexcavadoras y mixers.</p>
                </div>
            </div>

            <div class="group overflow-hidden rounded-xl shadow-md border border-gray-100 hover:shadow-xl transition">
                <div class="h-56 overflow-hidden">
                    <img src="/sector-industrial.jpg" alt="Industrial" class="w-full h-full object-cover group-hover:scale-110 transition duration-500">
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-bold text-blue-900 mb-2">Industrial</h3>
                    <p class="text-gray-500 text-sm">Montacargas y equipos de manipulación.</p>
                </div>
            </div>

            <div class="group overflow-hidden rounded-xl shadow-md border border-gray-100 hover:shadow-xl transition">
                <div class="h-56 overflow-hidden">
                    <img src="/sector-transporte.jpg" alt="Transporte" class="w-full h-full object-cover group-hover:scale-110 transition duration-500">
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-bold text-blue-900 mb-2">Camión & Bus</h3>
                    <p class="text-gray-500 text-sm">Máximo kilometraje para flotas de carga.</p>
                </div>
            </div>

        </div>
    </div>
</section>

    <section class="py-16 bg-gray-50 border-y border-gray-100">
    <div class="container mx-auto px-6">
        <div class="text-center mb-10">
            <p class="text-sm font-bold text-blue-900/40 uppercase tracking-[0.3em] mb-4">
                Distribuidores de Marcas Globales
            </p>
            <div class="w-12 h-0.5 bg-red-600/30 mx-auto"></div>
        </div>
        
        <div class="max-w-5xl mx-auto">
            <div class="relative group">
                <img 
                    src="/marcas-aliadas.jpg" 
                    alt="Marcas aliadas de STS: Michelin, Goodyear, Triangle y más" 
                    class="w-full h-auto grayscale opacity-70 group-hover:grayscale-0 group-hover:opacity-100 transition duration-700 ease-in-out mix-blend-multiply"
                />
            </div>
        </div>
    </div>
</section>

    <section id="catalogo" class="py-24 bg-blue-950 text-white relative">
        <div class="container mx-auto px-6 flex flex-col md:flex-row items-center gap-12">
            <div class="flex-1">
                <h2 class="text-4xl font-bold mb-6 italic">¿Busca especificaciones técnicas?</h2>
                <p class="text-blue-200 text-lg mb-8 leading-relaxed">
                    Nuestro portafolio actualizado incluye todas las medidas, índices de carga y diseños de banda de rodamiento.
                </p>
                <ul class="mb-10 space-y-4">
                    <li class="flex items-center gap-3"><span class="text-red-500 font-bold">✓</span> Precios competitivos</li>
                    <li class="flex items-center gap-3"><span class="text-red-500 font-bold">✓</span> Garantía de fábrica</li>
                    <li class="flex items-center gap-3"><span class="text-red-500 font-bold">✓</span> Despacho nacional</li>
                </ul>
                <a href="/catalogo-sts.pdf" class="inline-block bg-white text-blue-900 font-bold px-10 py-4 rounded-full shadow-lg hover:scale-105 transition transform">
                    DESCARGAR CATÁLOGO (PDF)
                </a>
            </div>
            <div class="flex-1">
                <img src="/almacen-sts.jpg" class="rounded-3xl shadow-2xl border-4 border-white/10 w-full h-auto" alt="Almacén STS">
            </div>
        </div>
    </section>

<footer id="nosotros" class="bg-white pt-20 pb-10 border-t border-gray-100">
        <div class="container mx-auto px-6">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16">
                <div>
                    <h4 class="font-black text-2xl text-blue-900 mb-6 uppercase">South Tires Solutions SAC</h4>
                    <p class="text-gray-500 italic">Aliados estratégicos en el sector, garantizando profesionalismo, ética y moral en cada venta.</p>
                </div>
                
                <div>
                    <h4 class="font-bold mb-6 text-blue-900">Ubicaciones</h4>
                    <div class="space-y-4">
                        <div class="text-gray-500">
                            <p>📍 <strong>Cañete:</strong> Jr. Garro 280, San Vicente.</p>
                            
                            <div class="mt-4 rounded-xl overflow-hidden shadow-sm border border-gray-100 h-48">
                                <iframe 
                                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3881.33234479577!2d-76.3888362!3d-13.0781044!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x910ff96057866e4d%3A0xc66578051a876793!2sJr.%20Garro%20280%2C%20San%20Vicente%20de%20Ca%C3%B1ete%20150d7!5e0!3m2!1ses-419!2spe!4v1710000000000!5m2!1ses-419!2spe" 
                                    width="100%" 
                                    height="100%" 
                                    style="border:0;" 
                                    allowfullscreen="" 
                                    loading="lazy" 
                                    referrerpolicy="no-referrer-when-downgrade">
                                </iframe>
                            </div>
                        </div>
                        <p class="text-gray-500 pt-2 border-t border-gray-50">
                            📍 <strong>Lima:</strong> Atención y despacho a nivel nacional.
                        </p>
                    </div>
                </div>

                <div>
                    <h4 class="font-bold mb-6 text-blue-900">Contacto Directo</h4>
                    <div class="space-y-3 text-gray-500">
                        <p>📧 <a href="mailto:ventas@stsllantas.com" class="hover:text-red-600 transition">ventas@stsllantas.com</a></p>
                        <p>📞 958 322 241 / 966 022 790</p>
                        <p>🏢 RUC: 20606471853</p>
                    </div>
                </div>
            </div>
            <div class="text-center text-gray-400 text-sm border-t border-gray-50 pt-10">
                &copy; 2026 South Tires Solutions SAC - Todos los derechos reservados.
            </div>
        </div>
    </footer>
    <a 
    href="https://wa.me/51958322241?text=Hola%20South%20Tires%20Solutions,%20solicito%20cotización%20e%20información%20sobre%20llantas." 
    target="_blank" 
    rel="noopener noreferrer"
    class="fixed bottom-8 right-8 z-[100] bg-[#25D366] text-white p-4 rounded-full shadow-2xl hover:scale-110 hover:bg-[#20ba5a] transition-all duration-300 group flex items-center justify-center"
    aria-label="Contactar por WhatsApp"
>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
